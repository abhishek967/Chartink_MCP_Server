# Chartink credentials (required for authenticated access)
CHARTINK_EMAIL=your-email@example.com
CHARTINK_PASSWORD=your-password

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Writable storage (cookies, SQLite). Local dev: project data/; Render: /tmp or set DATA_DIR
DATA_DIR=data

# Automated Chartink login on server (subprocess Playwright; requires email/password)
CHARTINK_AUTO_LOGIN=true
CHARTINK_STARTUP_AUTO_LOGIN=true

# Playwright (required for /refresh-session and scripts/login_test.py)
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=60000
# Render: set to .playwright-browsers and install in build (see scripts/render_build.sh)
PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers

# Webhook security (optional)
WEBHOOK_SECRET=

# Session refresh interval (minutes)
SESSION_REFRESH_INTERVAL_MINUTES=30

# Default Atlas dashboard for MCP tools
ATLAS_DEFAULT_DASHBOARD=5IvaWealth Advanced
