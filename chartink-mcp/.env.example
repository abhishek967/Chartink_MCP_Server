# Chartink credentials (required for authenticated access)
CHARTINK_EMAIL=your-email@example.com
CHARTINK_PASSWORD=your-password

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Database (SQLite by default)
DATABASE_URL=sqlite:///data/chartink.db

# Session persistence
COOKIES_FILE=data/cookies.json
FINDINGS_FILE=data/inspection_findings.json

# Startup browser login (off by default — sync Playwright must not run in asyncio lifespan)
CHARTINK_STARTUP_AUTO_LOGIN=false

# Playwright (required for /refresh-session and scripts/login_test.py)
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=60000

# Webhook security (optional)
WEBHOOK_SECRET=

# Session refresh interval (minutes)
SESSION_REFRESH_INTERVAL_MINUTES=30

# Default Atlas dashboard for MCP tools
ATLAS_DEFAULT_DASHBOARD=5IvaWealth Advanced
